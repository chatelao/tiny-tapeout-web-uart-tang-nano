
uart0: UART.CMSDK_APB_UART @ sysbus 0x40004000

tt_registers: Memory.MappedMemory @ sysbus 0x40002400
    size: 0x10

nvic: IRQControllers.NVIC @ sysbus 0xE000E000
    priorityMask: 0xFF
    systickFrequency: 27000000

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m3"
    nvic: nvic

sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x5800

rom: Memory.MappedMemory @ sysbus 0x00000000
    size: 0x8000
